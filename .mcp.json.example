{
  "//": "Template local do Claude Code. Copie para .mcp.json (gitignored), depois cole somente o token Coolify na copia.",
  "//setup": "Setup multiagente em docs/guides/0007-configurar-mcps-multiagente.md.",
  "mcpServers": {
    "hostinger-vps": {
      "//": "O MCP oficial pinado le HOSTINGER_API_TOKEN do .env via dotenv.",
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "--package",
        "hostinger-api-mcp@0.2.5",
        "hostinger-vps-mcp"
      ],
      "env": {}
    },
    "coolify": {
      "//": "Este MCP nao le .env. Cole o token somente na copia .mcp.json, que e gitignored.",
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@masonator/coolify-mcp@2.12.0"
      ],
      "env": {
        "COOLIFY_BASE_URL": "https://vps.thiagopanini.dev",
        "COOLIFY_ACCESS_TOKEN": "<COLE_O_TOKEN_DO_COOLIFY>"
      }
    },
    "cloudflare": {
      "//": "MCP remoto (http) — autenticação via OAuth no primeiro uso, sem token no arquivo. Ver docs/guides/0006-configurar-cloudflare-mcp.md.",
      "type": "http",
      "url": "https://mcp.cloudflare.com/mcp"
    }
  }
}
