# Copie para .env e ajuste. O .env nunca é commitado.

# API — conexão com o Postgres (usada a partir da fatia #173).
DATABASE_URL=postgresql+psycopg://travelmanager:travelmanager@localhost:5432/travelmanager

# API — pepper do HMAC das sessões (ADR-0004). Sem valor, cai num fallback de
# desenvolvimento inseguro; o segredo real entra só no go-live (#196).
SESSION_PEPPER=

# Web — segredo do Auth.js v5. Gere com `openssl rand -base64 32`.
# Nunca commitar um valor real.
AUTH_SECRET=

# Web — endpoint da API interna (rede privada; a API nunca é pública).
INTERNAL_API_URL=http://localhost:8000

# API — ambiente de execução. Em "production" a ausência de RESEND_API_KEY é erro
# fatal (impede que códigos OTP apareçam em claro nos logs do servidor).
# Não defina em desenvolvimento local.
APP_ENV=
